# =============================================================
# Docker Dev Stack – zmienne środowiskowe
# Skopiuj ten plik jako .env:
#   Windows cmd:        copy .env.example .env
#   PowerShell / bash:  cp .env.example .env
# =============================================================

# --- Baza danych MySQL ---
DB_NAME=devdb
DB_USER=devuser
DB_PASSWORD=devpassword
DB_ROOT_PASSWORD=rootpassword

# --- Porty (opcjonalnie zmień, jeśli są zajęte) ---
# APP_PORT=8080       # aplikacja PHP
# PMA_PORT=8081       # phpMyAdmin
# DB_EXTERNAL_PORT=3307  # MySQL dostępny z hosta

